# ===============================================
# 知信 (Zhixin) - 环境变量配置文件
# ===============================================
# 复制此文件为 .env 并修改相应配置
# cp .env.example .env
# ===============================================

# ============ MySQL 数据库配置 ============
# MySQL root 密码
MYSQL_ROOT_PASSWORD=ZhixinRoot@2026Secure

# 应用数据库名称
MYSQL_DATABASE=zhixin_chat

# 应用数据库用户名
MYSQL_USER=zhixin_user

# 应用数据库密码（建议使用强密码）
MYSQL_PASSWORD=ZhixinDB@2026Secure

# ============ MongoDB 配置 ============
# MongoDB 管理员用户名
MONGO_USER=mongo_admin

# MongoDB 管理员密码
MONGO_PASSWORD=ZhixinMongo@2026Secure

# MongoDB 数据库名称
MONGO_DB=zhixin_chat

# ============ Redis 配置 ============
# Redis 密码
REDIS_PASSWORD=ZhixinRedis@2026Secure

# ============ JWT 认证配置 ============
# JWT 密钥（必须修改为强随机密钥，至少32字符）
# 生成方法: openssl rand -base64 32
JWT_SECRET=please_generate_a_strong_random_key_here_replace_this

# ============ 应用配置 ============
# Gin 运行模式 (debug/release/test)
GIN_MODE=release

# 应用名称
APP_NAME=知信

# 应用版本
APP_VERSION=v1.0.0

# 服务监听端口
SERVER_PORT=8080

# ============ 集群部署配置（可选）============
# 节点ID（集群部署时每个节点必须不同）
# NODE_ID=backend-1

# ============ 文件存储配置 ============
# 存储类型: local (本地) / oss (阿里云) / cos (腾讯云) / s3 (AWS)
STORAGE_TYPE=local

# 本地存储路径
STORAGE_PATH=./uploads

# ============ 上传限制 ============
# 最大上传文件大小（字节，默认100MB）
MAX_UPLOAD_SIZE=104857600

# ============ 安全配置 ============
# 是否开启注册验证码 (true/false)
CAPTCHA_ENABLED=false

# 是否开启邀请码注册 (true/false)
INVITE_CODE_ENABLED=false

# 登录失败限制次数
LOGIN_MAX_ATTEMPTS=5

# 登录锁定时间（分钟）
LOGIN_LOCK_DURATION=30

# ============ 消息清理配置 ============
# 是否开启自动清理 (true/false)
AUTO_DELETE_ENABLED=true

# 自动清理天数（保留多少天的消息）
AUTO_DELETE_DAYS=30

# ============ 日志配置 ============
# 日志级别 (debug/info/warn/error)
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=./logs/zhixin.log

# ============ HTTPS/SSL 配置 ============
# SSL 证书路径
SSL_CERT_PATH=
SSL_KEY_PATH=

# ============ 邮件服务配置（用于找回密码等）============
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=知信 <noreply@example.com>

# ============ 对象存储配置（当 STORAGE_TYPE=oss/cos/s3 时）============
# 阿里云 OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=

# 腾讯云 COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET_NAME=
COS_REGION=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# ============ 微信/支付宝支付配置 ============
# 微信支付
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_NOTIFY_URL=

# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
