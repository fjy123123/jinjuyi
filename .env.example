# ========================================
# 知信聊天系统 - 环境配置示例
# ========================================
# 复制此文件为 .env 并修改配置值
# ========================================

# MySQL 数据库配置
MYSQL_ROOT_PASSWORD=your_strong_root_password_here
MYSQL_DATABASE=chat_system_pro
MYSQL_USER=chat_user
MYSQL_PASSWORD=your_strong_mysql_password_here

# MongoDB 配置
MONGO_USER=mongo_admin
MONGO_PASSWORD=your_strong_mongo_password_here
MONGO_DB=chat_system_pro

# Redis 配置
REDIS_PASSWORD=your_strong_redis_password_here

# JWT 密钥 (生产环境必须修改!)
# 可以使用以下命令生成: openssl rand -base64 64
JWT_SECRET=please_generate_a_strong_random_key_here_change_me_in_production

# Gin 模式 (debug/release/test)
GIN_MODE=release
